{
  "name": "@akitaroh/mermaid-mcp",
  "version": "0.2.0-dev",
  "description": "MCP server for MermaidMaker: shared canvas + structural query tools for AI agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mermaid-mcp": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:web && pnpm build:tsc && pnpm build:copy-web",
    "build:web": "pnpm --filter @akitaroh/mermaid-maker-web build",
    "build:tsc": "tsc",
    "build:copy-web": "node scripts/copy-web.mjs",
    "test": "vitest run",
    "start": "tsx src/bin.ts",
    "dev": "tsx watch src/bin.ts"
  },
  "dependencies": {
    "@akitaroh/mermaid-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
